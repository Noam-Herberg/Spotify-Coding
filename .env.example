# Create an app at https://developer.spotify.com/dashboard.
# Add: http://127.0.0.1:3000/api/auth/callback
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
APP_URL=http://127.0.0.1:3000

# Neon pooled Postgres connection string. Vercel's Neon integration normally
# supplies POSTGRES_URL automatically; DATABASE_URL is also supported.
POSTGRES_URL=postgresql://user:password@host/database?sslmode=require
# Prefer a direct connection for migrations when available.
POSTGRES_URL_NON_POOLING=postgresql://user:password@host/database?sslmode=require

# Generate two different long random values. Keep both private.
SESSION_SECRET=replace_with_at_least_32_random_characters
TOKEN_ENCRYPTION_KEY=replace_with_at_least_32_random_characters
